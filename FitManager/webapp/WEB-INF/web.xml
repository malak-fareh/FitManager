<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_3_1.xsd"
         version="3.1">
<display-name>FitManager</display-name>
<!--  ============================================================
         Paramètres JDBC globaux (lus par DBConnection.getConnection)
         Modifiez ces valeurs selon votre environnement local
         ============================================================  -->
<context-param>
<param-name>jdbc.url</param-name>
<param-value>jdbc:mysql://localhost:3306/fitmanager?useSSL=false&serverTimezone=Africa/Tunis&allowPublicKeyRetrieval=true</param-value>
</context-param>
<context-param>
<param-name>jdbc.user</param-name>
<param-value>root</param-value>
</context-param>
<context-param>
<param-name>jdbc.password</param-name>
<param-value/>
</context-param>
<!--  ============================================================
         Filtre UTF-8 global
         ============================================================  -->
<filter>
<filter-name>EncodingFilter</filter-name>
<filter-class>com.fitmanager.filter.EncodingFilter</filter-class>
</filter>
<filter-mapping>
<filter-name>EncodingFilter</filter-name>
<url-pattern>/*</url-pattern>
</filter-mapping>
<!--  ============================================================
         Servlets
         ============================================================  -->
<!--  Session (JSON état connecté/invité)  -->
<servlet>
<servlet-name>SessionServlet</servlet-name>
<servlet-class>com.fitmanager.servlet.SessionServlet</servlet-class>
</servlet>
<servlet-mapping>
<servlet-name>SessionServlet</servlet-name>
<url-pattern>/api/session</url-pattern>
</servlet-mapping>
<!--  Connexion  -->
<servlet>
<servlet-name>LoginServlet</servlet-name>
<servlet-class>com.fitmanager.servlet.LoginServlet</servlet-class>
</servlet>
<servlet-mapping>
<servlet-name>LoginServlet</servlet-name>
<url-pattern>/login</url-pattern>
</servlet-mapping>
<!--  Déconnexion  -->
<servlet>
<servlet-name>LogoutServlet</servlet-name>
<servlet-class>com.fitmanager.servlet.LogoutServlet</servlet-class>
</servlet>
<servlet-mapping>
<servlet-name>LogoutServlet</servlet-name>
<url-pattern>/logout</url-pattern>
</servlet-mapping>
<!--  Inscription  -->
<servlet>
<servlet-name>RegisterServlet</servlet-name>
<servlet-class>com.fitmanager.servlet.RegisterServlet</servlet-class>
</servlet>
<servlet-mapping>
<servlet-name>RegisterServlet</servlet-name>
<url-pattern>/register</url-pattern>
</servlet-mapping>
<!--  Abonnements  -->
<servlet>
<servlet-name>AbonnementServlets</servlet-name>
<servlet-class>com.fitmanager.servlet.AbonnementServlets</servlet-class>
</servlet>
<servlet-mapping>
<servlet-name>AbonnementServlets</servlet-name>
<url-pattern>/abonnements</url-pattern>
</servlet-mapping>
<!--  Statistiques  -->
<servlet>
<servlet-name>StatsServlets</servlet-name>
<servlet-class>com.fitmanager.servlet.StatsServlets</servlet-class>
</servlet>
<servlet-mapping>
<servlet-name>StatsServlets</servlet-name>
<url-pattern>/stats</url-pattern>
</servlet-mapping>
<!--  ============================================================
         Session
         ============================================================  -->
<session-config>
<session-timeout>30</session-timeout>
<cookie-config>
<http-only>true</http-only>
</cookie-config>
</session-config>
<!--  Page d'accueil par défaut  -->
<welcome-file-list>
<welcome-file>index.html</welcome-file>
</welcome-file-list>
<!-- Locaux -->
<servlet>
    <servlet-name>LocalServlets</servlet-name>
    <servlet-class>com.fitmanager.servlet.LocalServlets</servlet-class>
</servlet>
<servlet-mapping>
    <servlet-name>LocalServlets</servlet-name>
    <url-pattern>/locaux-api</url-pattern>
</servlet-mapping>

<!-- Réservations -->
<servlet>
    <servlet-name>ReservationServlets</servlet-name>
    <servlet-class>com.fitmanager.servlet.ReservationServlets</servlet-class>
</servlet>
<servlet-mapping>
    <servlet-name>ReservationServlets</servlet-name>
    <url-pattern>/reservations</url-pattern>
</servlet-mapping>
</web-app>